# HuggingFace Configuration
HF_MODEL_ID=Qwen/Qwen2.5-3B-Instruct
HF_ADAPTER_PATH=
HF_TOKEN=your_huggingface_token_here
HF_ENDPOINT_URL=
HF_TIMEOUT=10.0

# Priority used by hf_llm_agent:
# 1) Hosted HF when HF_ENDPOINT_URL is set (or HF_TOKEN set without HF_ADAPTER_PATH)
# 2) Local LoRA adapter when HF_ADAPTER_PATH is set (e.g. outputs/cysent_unsloth_adapter)
# 3) PPO fallback when HF init/predict fails

# Agent Configuration
DEFAULT_AGENT=ppo_agent
AGENT_MODE=hybrid
HYBRID_THRESHOLD=10

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000